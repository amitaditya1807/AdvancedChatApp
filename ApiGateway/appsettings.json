{
    "ReverseProxy": {
        "Routes": {
            "authRoute": {
                "ClusterId": "authCluster",
                "Match": {
                    "Path": "/auth/{**catch-all}"
                }
            },
            "googleSigninRoute": {
                "ClusterId": "authCluster",
                "Match": {
                    "Path": "/signin-google"
                }
            },
            "chatRootRoute": {
                "ClusterId": "chatCluster",
                "Match": {
                    "Path": "/chat"
                }
            },
            "chatRoute": {
                "ClusterId": "chatCluster",
                "Match": {
                    "Path": "/chat/{**catch-all}"
                }
            }
        },
        "Clusters": {
            "authCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://localhost:7001/"
                    }
                }
            },
            "chatCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://localhost:5000/"
                    }
                }
            }
        }
    }
}