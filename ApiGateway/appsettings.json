{
    "ReverseProxy": {
        "Routes": {
            "authRoute": {
                "ClusterId": "authCluster",
                "Match": {
                    "Path": "/auth/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/auth" }
                ]
            },
            "chatRoute": {
                "ClusterId": "chatCluster",
                "Match": {
                    "Path": "/chat/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/chat" }
                ]
            }
        },
        "Clusters": {
            "authCluster": {
                "Destinations": {
                    "authDestination": {
                        "Address": "https://localhost:7001/"
                    }
                }
            },
            "chatCluster": {
                "Destinations": {
                    "chatDestination": {
                        "Address": "https://localhost:5000/"
                    }
                }
            }
        }
    }
}