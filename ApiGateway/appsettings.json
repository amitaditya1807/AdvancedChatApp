{
    "ReverseProxy": {
        "Routes": {
            "authRoute": {
                "ClusterId": "authCluster",
                "Match": {
                    "Path": "/auth/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/auth" }
                ]
            },
            "chatRoute": {
                "ClusterId": "chatCluster",
                "Match": {
                    "Path": "/chat/{**catch-all}"
                }
            }
        },
        "Clusters": {
            "authCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://advancedchatapp.onrender.com"
                    }
                }
            },
            "chatCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://chatservice-hanj.onrender.com"
                    }
                }
            }
        }
    }
}