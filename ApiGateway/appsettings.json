{
    "ReverseProxy": {
        "Routes": {
            "authRoute": {
                "ClusterId": "authCluster",
                "Match": {
                    "Path": "/auth/{**catch-all}"
                }
            },
            "googleSigninRoute": {
                "ClusterId": "authCluster",
                "Match": {
                    "Path": "/signin-google"
                }
            },
            "chatRootRoute": {
                "ClusterId": "chatCluster",
                "Match": {
                    "Path": "/chat"
                }
            },
            "chatRoute": {
                "ClusterId": "chatCluster",
                "Match": {
                    "Path": "/chat/{**catch-all}"
                }
            },
            "cloudStorageRootRoute": {
                "ClusterId": "cloudStorageCluster",
                "Match": {
                    "Path": "/cloudstorage"
                },
                "Transforms": [
                    {
                        "PathRemovePrefix": "/cloudstorage"
                    }
                ]
            },
            "cloudStorageRoute": {
                "ClusterId": "cloudStorageCluster",
                "Match": {
                    "Path": "/cloudstorage/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathRemovePrefix": "/cloudstorage"
                    }
                ]
            }
        },
        "Clusters": {
            "authCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://advancechatapp-nltm.onrender.com/"
                    }
                }
            },
            "chatCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://chatservice1.onrender.com/"
                    }
                }
            },
            "cloudStorageCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://cloudstorageservice.onrender.com/"
                    }
                }
            }
        }
    }
}
